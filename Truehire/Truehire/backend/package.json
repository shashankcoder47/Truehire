{
  "name": "truehire-backend",
  "version": "1.0.0",
  "description": "Backend API for TrueHire job portal",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js",
    "test:unit": "npm test -- --runInBand tests/unit",
    "generate": "prisma generate",
    "migrate": "node scripts/run-mysql-migrations.js",
    "migrate:mysql": "node scripts/run-mysql-migrations.js",
    "migrate:prisma": "prisma migrate dev",
    "reset": "prisma migrate reset",
    "push": "prisma db push",
    "seed": "node database/seeds/seed.js",
    "studio": "prisma studio"
  },
  "prisma": {
    "seed": "node database/seeds/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.812.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "mysql2": "^3.15.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "razorpay": "^2.9.6",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "jest-junit": "^17.0.0",
    "nodemon": "^3.0.2",
    "prisma": "^6.7.0"
  }
}
