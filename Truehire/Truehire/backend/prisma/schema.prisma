  razorpay_payment_id String?             @db.VarChar(255)
  created_at          DateTime?           @default(now()) @db.Timestamp(0)
  updated_at          DateTime?           @default(now()) @db.Timestamp(0)
  subscription_plans  subscription_plans? @relation(fields: [plan_id], references: [id], onDelete: Restrict, map: "fk_payments_plan")
  recruiters          recruiters          @relation(fields: [recruiter_id], references: [id], onDelete: Cascade, map: "fk_payments_recruiter")

  @@index([plan_id], map: "idx_payments_plan")
  @@index([recruiter_id], map: "idx_payments_recruiter")
  @@index([status], map: "idx_payments_status")
  @@index([transaction_id], map: "idx_payments_transaction")
}

