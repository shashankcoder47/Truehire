  @@index([recipient_type], map: "idx_notifications_recipient_type")
  @@index([sent_at], map: "idx_notifications_sent_at")
  @@index([status], map: "idx_notifications_status")
  @@index([type], map: "idx_notifications_type")
}

model otp_codes {
  id         BigInt    @id @default(autoincrement())
  email      String    @db.VarChar(150)
  otp_code   String    @db.VarChar(10)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  expires_at DateTime  @db.Timestamp(0)

  @@index([email], map: "idx_otp_email")
  @@index([expires_at], map: "idx_otp_expires")
