generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admins {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(100)
  email      String    @unique(map: "admins_email_key") @db.VarChar(150)
  password   String    @db.VarChar(255)
  role       String    @default("ADMIN") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
}

model application_conversations {
  id                             BigInt                 @id @default(autoincrement())
  application_id                 BigInt
  job_id                         BigInt
  recruiter_id                   BigInt
  user_id                        BigInt
  last_message_id                BigInt?
  last_message_at                DateTime?              @db.Timestamp(0)
  recruiter_notes                String?                @db.Text
  user_unread_email_sent_at      DateTime?              @db.Timestamp(0)
  recruiter_unread_email_sent_at DateTime?              @db.Timestamp(0)
  user_last_seen_message_id      BigInt?
  user_seen_at                   DateTime?              @db.Timestamp(0)
  recruiter_last_seen_message_id BigInt?
  recruiter_seen_at              DateTime?              @db.Timestamp(0)
  created_at                     DateTime?              @default(now()) @db.Timestamp(0)
  updated_at                     DateTime?              @default(now()) @db.Timestamp(0)
  job_applications               job_applications       @relation(fields: [application_id], references: [id], onDelete: Cascade, map: "fk_appconv_application")
  jobs                           jobs                   @relation(fields: [job_id], references: [id], onDelete: Cascade, map: "fk_appconv_job")
  recruiters                     recruiters             @relation(fields: [recruiter_id], references: [id], onDelete: Cascade, map: "fk_appconv_recruiter")
  users                          users                  @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_appconv_user")
  application_messages           application_messages[]

  @@index([application_id], map: "idx_appconv_application")
  @@index([job_id], map: "idx_appconv_job")
  @@index([recruiter_id], map: "idx_appconv_recruiter")
  @@index([user_id], map: "idx_appconv_user")
}

model application_message_attachments {
  id                   BigInt               @id @default(autoincrement())
  message_id           BigInt
  file_path            String               @db.VarChar(500)
  file_name            String               @db.VarChar(255)
  file_type            String?              @db.VarChar(100)
  file_size            BigInt?
  created_at           DateTime?            @default(now()) @db.Timestamp(0)
  application_messages application_messages @relation(fields: [message_id], references: [id], onDelete: Cascade, map: "fk_app_msg_attach_message")

  @@index([message_id], map: "idx_app_msg_attach_message")
}

model application_messages {
  id                              BigInt                               @id @default(autoincrement())
  conversation_id                 BigInt
  application_id                  BigInt
  job_id                          BigInt
  sender_id                       BigInt
  sender_role                     String?                              @db.VarChar(11)
  receiver_id                     BigInt
  receiver_role                   String?                              @db.VarChar(11)
  message                         String                               @db.Text
  read_status                     Boolean?                             @default(false)
  read_at                         DateTime?                            @db.Timestamp(0)
  is_pinned                       Boolean?                             @default(false)
  pinned_at                       DateTime?                            @db.Timestamp(0)
  pinned_by_role                  String?                              @db.VarChar(11)
  pinned_by_id                    BigInt?
  created_at                      DateTime?                            @default(now()) @db.Timestamp(0)
  application_message_attachments application_message_attachments[]
  job_applications                job_applications                     @relation(fields: [application_id], references: [id], onDelete: Cascade, map: "fk_app_messages_application")
  application_conversations       application_conversations            @relation(fields: [conversation_id], references: [id], onDelete: Cascade, map: "fk_app_messages_conversation")
  jobs                            jobs                                 @relation(fields: [job_id], references: [id], onDelete: Cascade, map: "fk_app_messages_job")

  @@index([application_id], map: "idx_app_messages_application")
  @@index([conversation_id], map: "idx_app_messages_conversation")
  @@index([job_id], map: "idx_app_messages_job")
  @@index([read_status], map: "idx_app_messages_read")
  @@index([receiver_id], map: "idx_app_messages_receiver")
  @@index([sender_id], map: "idx_app_messages_sender")
}

model applications {
  id                         BigInt                    @id @default(autoincrement())
  job_id                     BigInt
  user_id                    BigInt
  name                       String                    @db.VarChar(150)
  email                      String                    @db.VarChar(150)
  phone                      String?                   @db.VarChar(20)
  location                   String?                   @db.VarChar(150)
  experience_level           String?                   @db.VarChar(100)
  current_salary             Decimal?                  @db.Decimal(12, 2)
  expected_salary            Decimal?                  @db.Decimal(12, 2)
  notice_period              Int?
  additional_comments        String?                   @db.Text
  resume_path                String?                   @db.VarChar(500)
  match_score                Int?
  matched_skills             String?                   @db.Text
  missing_skills             String?                   @db.Text
  match_status               String?                   @default("MATCHED") @db.VarChar(30)
  applied_at                 DateTime?                 @default(now()) @db.Timestamp(0)
  recruiter_last_action_at   DateTime?                 @db.Timestamp(0)
  smart_suggestion_triggered Boolean?                  @default(false)
  smart_timer_started_at     DateTime?                 @db.Timestamp(0)
  created_at                 DateTime?                 @default(now()) @db.Timestamp(0)
  updated_at                 DateTime?                 @default(now()) @db.Timestamp(0)
  jobs                       jobs                      @relation(fields: [job_id], references: [id], onDelete: Cascade, map: "fk_app_job")
  users                      users                     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_app_user")
  recruiter_notifications    recruiter_notifications[]
  user_notifications         user_notifications[]

  @@index([email], map: "idx_app_email")
  @@index([job_id], map: "idx_app_job")
  @@index([user_id], map: "idx_app_user")
}

model banner_images {
  id            BigInt        @id @default(autoincrement())
  title         String        @db.VarChar(200)
  image_path    String        @db.VarChar(500)
  image_url     String?       @db.VarChar(500)
  is_active     Boolean?      @default(true)
  display_order Int?          @default(0)
  uploaded_by   BigInt?
  created_at    DateTime?     @default(now()) @db.Timestamp(0)
  updated_at    DateTime?     @default(now()) @db.Timestamp(0)
  super_admins  super_admins? @relation(fields: [uploaded_by], references: [id], map: "fk_banner_uploaded_by")

  @@index([uploaded_by], map: "idx_banner_uploaded_by")
  @@index([is_active], map: "idx_banner_active")
  @@index([display_order], map: "idx_banner_display_order")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model certifications {
  id                   BigInt    @id @default(autoincrement())
  user_id              BigInt
  certification_name   String    @db.VarChar(200)
  issuing_organization String?   @db.VarChar(200)
  issue_date           DateTime? @db.Date
  expiry_date          DateTime? @db.Date
  credential_id        String?   @db.VarChar(150)
  credential_url       String?   @db.VarChar(300)
  created_at           DateTime? @default(now()) @db.Timestamp(0)
  updated_at           DateTime? @default(now()) @db.Timestamp(0)
  users                users     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_certifications_user")

  @@index([issue_date], map: "idx_certifications_issue_date")
  @@index([certification_name], map: "idx_certifications_name")
  @@index([user_id], map: "idx_certifications_user")
}

model companies {
  id                    BigInt     @id @default(autoincrement())
  recruiter_id          BigInt
  company_name          String     @db.VarChar(200)
  company_type          String?    @db.VarChar(100)
  industry              String?    @db.VarChar(150)
  company_size          String?    @db.VarChar(100)
  year_founded          Int?       
  official_email        String?    @db.VarChar(150)
  phone_number          String?    @db.VarChar(20)
  website               String?    @db.VarChar(300)
  headquarters_location String?    @db.VarChar(200)
  short_overview        String?    @db.Text
  detailed_description  String?    @db.Text
  company_logo          String?    @db.VarChar(500)
  linkedin              String?    @db.VarChar(300)
  instagram             String?    @db.VarChar(300)
  facebook              String?    @db.VarChar(300)
  profile_complete      Boolean?   @default(false)
  created_at            DateTime?  @default(now()) @db.Timestamp(0)
  updated_at            DateTime?  @default(now()) @db.Timestamp(0)
  recruiters            recruiters @relation(fields: [recruiter_id], references: [id], onDelete: Cascade, map: "fk_companies_recruiter")

  @@index([industry], map: "idx_companies_industry")
  @@index([company_name], map: "idx_companies_name")
  @@index([recruiter_id], map: "idx_companies_recruiter")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model company_ratings {
  id         BigInt     @id @default(autoincrement())
  company_id BigInt
  user_id    BigInt
  rating     Int
  created_at DateTime?  @default(now()) @db.Timestamp(0)
  updated_at DateTime?  @default(now()) @db.Timestamp(0)
  recruiters recruiters @relation(fields: [company_id], references: [id], onDelete: Cascade, map: "fk_company_ratings_company")
  users      users      @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_company_ratings_user")

  @@unique([company_id, user_id], map: "unique_company_user")
  @@index([company_id], map: "idx_company_ratings_company")
  @@index([rating], map: "idx_company_ratings_rating")
  @@index([user_id], map: "idx_company_ratings_user")
}

model favourite_companies {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  company_id BigInt
  created_at DateTime? @default(now()) @db.Timestamp(0)

  @@unique([user_id, company_id], map: "uniq_favourite_companies_user_company")
  @@index([company_id], map: "idx_favourite_companies_company")
  @@index([user_id], map: "idx_favourite_companies_user")
}

model favourite_notifications {
  id          BigInt                               @id @default(autoincrement())
  user_id     BigInt
  type        String?                              @db.VarChar(19)
  title       String                               @db.VarChar(255)
  message     String                               @db.Text
  entity_type String?                              @default("JOB") @db.VarChar(7)
  entity_id   BigInt?
  is_read     Boolean?                             @default(false)
  created_at  DateTime?                            @default(now()) @db.Timestamp(0)

  @@index([created_at], map: "idx_created")
  @@index([user_id, is_read], map: "idx_read")
  @@index([user_id], map: "idx_favourite_notifications_user")
}

model introduction_videos {
  id               BigInt           @id @default(autoincrement())
  application_id   BigInt
  user_id          BigInt
  job_id           BigInt
  recruiter_id     BigInt
  file_name        String           @db.VarChar(255)
  file_path        String           @db.VarChar(500)
  file_size        BigInt?
  duration_seconds Int?
  uploaded_at      DateTime?        @default(now()) @db.Timestamp(0)
  created_at       DateTime?        @default(now()) @db.Timestamp(0)
  updated_at       DateTime?        @default(now()) @db.Timestamp(0)
  job_applications job_applications @relation(fields: [application_id], references: [id], onDelete: Cascade, map: "fk_intro_videos_application")
  jobs             jobs             @relation(fields: [job_id], references: [id], onDelete: Cascade, map: "fk_intro_videos_job")
  recruiters       recruiters       @relation(fields: [recruiter_id], references: [id], onDelete: Cascade, map: "fk_intro_videos_recruiter")
  users            users            @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_intro_videos_user")

  @@index([application_id], map: "idx_intro_videos_application")
  @@index([job_id], map: "idx_intro_videos_job")
  @@index([recruiter_id], map: "idx_intro_videos_recruiter")
  @@index([user_id], map: "idx_intro_videos_user")
}

model job_applications {
  id                         BigInt                      @id @default(autoincrement())
  job_id                     BigInt
  user_id                    BigInt
  status                     String?                     @default("APPLIED") @db.VarChar(11)
  applied_at                 DateTime?                   @default(now()) @db.Timestamp(0)
  notes                      String?                     @db.Text
  total_view_seconds         Int?                        @default(0)
  rejection_reason           String?                     @db.Text
  recruiter_last_action_at   DateTime?                   @db.Timestamp(0)
  smart_timer_started_at     DateTime?                   @db.Timestamp(0)
  smart_suggestion_triggered Boolean?                    @default(false)
  updated_at                 DateTime?                   @default(now()) @db.Timestamp(0)
  application_conversations  application_conversations[]
  application_messages       application_messages[]
  introduction_videos        introduction_videos[]
  jobs                       jobs                        @relation(fields: [job_id], references: [id], onDelete: Cascade, map: "fk_job_applications_job")
  users                      users                       @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_job_applications_user")

  @@unique([job_id, user_id], map: "unique_job_user")
  @@index([job_id], map: "idx_job_applications_job")
  @@index([status], map: "idx_job_applications_status")
  @@index([user_id], map: "idx_job_applications_user")
}

model jobs {
  id                            BigInt                      @id @default(autoincrement())
  recruiter_id                  BigInt
  title                         String                      @db.VarChar(200)
  company                       String?                     @db.VarChar(200)
  location                      String?                     @db.VarChar(150)
  employment_type               String?                     @db.VarChar(50)
  experience_level              String?                     @db.VarChar(16)
  salary_min                    Decimal?                    @db.Decimal(12, 2)
  salary_max                    Decimal?                    @db.Decimal(12, 2)
  salary_currency               String?                     @default("INR") @db.VarChar(10)
  description                   String?                     @db.Text
  requirements                  String?                     @db.Text
  benefits                      String?                     @db.Text
  skills_required               String?                     @db.Text
  min_experience_years          Decimal?                    @db.Decimal(4, 1)
  match_percentage              Int?                        @default(0)
  application_deadline          DateTime?                   @db.Date
  status                        String?                     @default("DRAFT") @db.VarChar(6)
  is_featured                   Boolean?                    @default(false)
  is_urgent                     Boolean?                    @default(false)
  views_count                   Int?                        @default(0)
  applications_count            Int?                        @default(0)
  deadline_notification_sent_at DateTime?                   @db.Timestamp(0)
  created_at                    DateTime?                   @default(now()) @db.Timestamp(0)
  updated_at                    DateTime?                   @default(now()) @db.Timestamp(0)
  closed_at                     DateTime?                   @db.Timestamp(0)
  company_logo                  String?                     @db.VarChar(500)
  max_applicants                Int?
  application_conversations     application_conversations[]
  application_messages          application_messages[]
  applications                  applications[]
  introduction_videos           introduction_videos[]
  job_applications              job_applications[]
  recruiters                    recruiters                  @relation(fields: [recruiter_id], references: [id], onDelete: Cascade, map: "fk_jobs_recruiter")
  saved_jobs                    saved_jobs[]

  @@index([location], map: "idx_jobs_location")
  @@index([recruiter_id], map: "idx_jobs_recruiter")
  @@index([status], map: "idx_jobs_status")
}

model migrations {
  id     BigInt   @id @default(autoincrement())
  name   String   @unique(map: "name") @db.VarChar(255)
  run_on DateTime @default(now()) @db.Timestamp(0)

  @@index([name], map: "idx_migrations_name")
  @@index([run_on], map: "idx_migrations_run_on")
}

model notifications {
  id             BigInt                       @id @default(autoincrement())
  type           String                       @db.VarChar(100)
  title          String                       @db.VarChar(200)
  message        String                       @db.Text
  recipient_type String?                      @db.VarChar(11)
