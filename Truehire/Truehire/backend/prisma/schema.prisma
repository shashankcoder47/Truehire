model recruiters {
  id                               BigInt                             @id @default(autoincrement())
  recruiter_id                     String?                            @unique(map: "recruiter_id") @db.VarChar(100)
  name                             String                             @db.VarChar(150)
  email                            String                             @unique(map: "recruiters_email_key") @db.VarChar(150)
  password                         String?                            @db.VarChar(255)
  company                          String?                            @db.VarChar(200)
  role                             String?                            @default("RECRUITER") @db.VarChar(13)
  status                           String?                            @default("ACTIVE") @db.VarChar(8)
  profile_complete                 Boolean?                           @default(false)
  job_post_limit                   Int?                               @default(0)
  subscription_status              String?                            @db.VarChar(9)
  subscription_expiry              DateTime?                          @db.Date
  sub_recruiters                   Int?                               @default(0)
  company_name                     String?                            @db.VarChar(200)
  company_type                     String?                            @db.VarChar(100)
