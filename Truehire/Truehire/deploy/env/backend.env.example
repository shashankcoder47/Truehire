NODE_ENV=production
PORT=5000
HOST=0.0.0.0
TRUST_PROXY_HOPS=1
CLUSTER_ENABLED=true
WEB_CONCURRENCY=2
CRON_JOBS_ENABLED=true

DATABASE_URL=mysql://truehire_admin:CHANGE_ME@YOUR_RDS_ENDPOINT:3306/truehire
DB_CONNECTION_LIMIT=10
DB_POOL_TIMEOUT=10
FRONTEND_URL=https://example.com
JWT_SECRET=CHANGE_ME_TO_A_32_PLUS_CHARACTER_RANDOM_SECRET
JWT_EXPIRES_IN=2h
JWT_ISSUER=truehire-api
JWT_AUDIENCE=truehire-web

RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE=database
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10
JSON_BODY_LIMIT=1mb
FORM_BODY_LIMIT=1mb

AWS_REGION=ap-south-1
AWS_S3_BUCKET=YOUR_TERRAFORM_S3_BUCKET_OUTPUT
AWS_S3_PUBLIC_URL=https://YOUR_TERRAFORM_S3_BUCKET_OUTPUT.s3.ap-south-1.amazonaws.com

GOOGLE_CLIENT_ID=CHANGE_ME
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=CHANGE_ME
EMAIL_PASS=CHANGE_ME

RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

